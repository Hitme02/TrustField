  "RoleDetailList": [
    {
      "RoleId": "AROAEXAMPLEDEPLOYROLE",
      "RoleName": "deploy-role",
      "Arn": "arn:aws:iam::123456789012:role/deploy-role",
      "AssumeRolePolicyDocument": {
        "Version": "2012-10-17",
        "Statement": [
          { "Effect": "Allow",
            "Principal": { "AWS": [
              "arn:aws:iam::123456789012:user/dev-alice",
              "arn:aws:iam::123456789012:user/dev-bob",
              "arn:aws:iam::123456789012:group/CIPipeline"
            ]},
            "Action": "sts:AssumeRole" }
        ]
      },
      "RolePolicyList": [
        {
          "PolicyName": "EscalateToAdmin",
          "PolicyDocument": {
            "Version": "2012-10-17",
            "Statement": [
              { "Effect": "Allow", "Action": "sts:AssumeRole",
                "Resource": [
                  "arn:aws:iam::123456789012:role/infra-admin-role",
                  "arn:aws:iam::123456789012:role/lambda-invoke-role"
                ]}
            ]
          }
        }
      ],
      "AttachedManagedPolicies": [
        { "PolicyName": "LambdaDeployPolicy", "PolicyArn": "arn:aws:iam::123456789012:policy/LambdaDeployPolicy" }
      ]
    },
    {
      "RoleId": "AROAEXAMPLEAPIROLE",
      "RoleName": "api-execution-role",
      "Arn": "arn:aws:iam::123456789012:role/api-execution-role",
      "AssumeRolePolicyDocument": {
        "Version": "2012-10-17",
        "Statement": [
          { "Effect": "Allow",
            "Principal": { "Service": "lambda.amazonaws.com" },
            "Action": "sts:AssumeRole" },
          { "Effect": "Allow",
            "Principal": { "AWS": "arn:aws:iam::123456789012:role/lambda-invoke-role" },
            "Action": "sts:AssumeRole" }
        ]
      },
      "RolePolicyList": [
        {
          "PolicyName": "ReadDbSecrets",
          "PolicyDocument": {
            "Version": "2012-10-17",
            "Statement": [
              { "Effect": "Allow",
                "Action": ["secretsmanager:GetSecretValue", "kms:Decrypt"],
                "Resource": "arn:aws:secretsmanager:us-east-1:123456789012:secret:prod/db-credentials" },
              { "Effect": "Allow", "Action": "sts:AssumeRole",
                "Resource": "arn:aws:iam::123456789012:role/secrets-reader-role" }
            ]
          }
        }
      ],
      "AttachedManagedPolicies": []
    },
    {
      "RoleId": "AROAEXAMPLEADMINROLE",
